{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=OpenData.sqlite;Cache=Shared"
  },
  "Auth": {
    "Authority": "https://localhost:5001"
  },
  "Cors": {
    "Urls": [ "http://localhost:5000" ]
  },
  "Polly": {
    "Retry": 3
  }
}